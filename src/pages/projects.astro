---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/cv';
---

<BaseLayout title="Projects" description="Open source and side projects by Kiran Capoor.">
  <div class="container page">
    <p class="prompt-line"><span class="prompt">ls -la ~/projects</span></p>
    <h1><span class="hash">#</span> projects</h1>
    <p class="intro muted">// open source and side projects — mostly tooling for the way I work.</p>

    <div class="project-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <h2><span class="dir-icon">drwxr-xr-x</span> {project.name}/</h2>
            <p>{project.description}</p>
            {project.link && (
              <a href={project.link} target="_blank" rel="noopener noreferrer">
                cd {project.name.toLowerCase()}/ &rarr;
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>

  <style>
    .page {
      padding: 3rem 1.5rem 4rem;
    }

    .prompt-line {
      margin-bottom: 0.5rem;
    }

    h1 {
      font-size: 1.8rem;
      margin: 0 0 0.5rem;
      color: var(--color-cyan);
    }

    .hash {
      color: var(--color-magenta);
    }

    .intro {
      margin-bottom: 2.5rem;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .project-card {
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 1.5rem;
      background: var(--color-bg-alt);
    }

    .project-card:hover {
      border-color: var(--color-accent);
    }

    .project-card h2 {
      font-size: 1rem;
      margin: 0 0 0.6rem;
      color: var(--color-yellow);
    }

    .dir-icon {
      color: var(--color-text-muted);
      font-size: 0.75rem;
    }

    .project-card p {
      color: var(--color-text-muted);
      font-size: 0.9rem;
      margin: 0 0 0.75rem;
    }
  </style>
</BaseLayout>
