---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile, experience, skills, education, certifications } from '../data/cv';
---

<BaseLayout title="About" description={profile.summary[0]}>
  <div class="container page">
    <p class="prompt-line"><span class="prompt">cat about.md</span></p>
    <h1><span class="hash">#</span> about</h1>

    <section class="block">
      {profile.summary.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    <section class="block" data-reveal>
      <h2><span class="hash">##</span> experience</h2>
      <p class="section-tagline muted">// the paid version of side projects, in reverse-chronological order.</p>
      <div class="timeline">
        {
          experience.map((job) => (
            <article class="job">
              <div class="job-head">
                <h3>{job.role} <span class="at">@</span> {job.company}</h3>
                <span class="period">{job.period}</span>
              </div>
              <p class="company">// {job.location}</p>
              <ul>
                {job.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="block" data-reveal>
      <h2><span class="hash">##</span> skills</h2>
      <p class="section-tagline muted">// what shows up in `git blame` most often.</p>
      <div class="skill-grid">
        {
          skills.map((group) => (
            <div class="skill-group">
              <h3>{group.group}</h3>
              <div>
                {group.items.map((item) => (
                  <span class="tag-pill">{item}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="block" data-reveal>
      <h2><span class="hash">##</span> education</h2>
      <p class="section-tagline muted">// a chemistry degree that mostly taught me to debug things I can't see.</p>
      <p>
        <strong>{education.degree}</strong> &mdash; {education.school}
        <br />
        <span class="muted">// {education.period}, {education.location}</span>
      </p>
    </section>

    <section class="block" data-reveal>
      <h2><span class="hash">##</span> certifications</h2>
      <ul class="cert-list">
        {certifications.map((cert) => <li>{cert}</li>)}
      </ul>
    </section>
  </div>

  <style>
    .page {
      padding: 3rem 1.5rem 4rem;
    }

    .prompt-line {
      margin-bottom: 0.5rem;
    }

    h1 {
      font-size: 1.8rem;
      margin: 0 0 2rem;
      color: var(--color-cyan);
    }

    .hash {
      color: var(--color-magenta);
    }

    .at {
      color: var(--color-text-muted);
    }

    .block {
      margin-bottom: 3rem;
    }

    .block h2 {
      font-size: 1.1rem;
      margin-bottom: 0.4rem;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.5rem;
      color: var(--color-text);
    }

    .section-tagline {
      margin: 0.6rem 0 1.25rem;
      font-size: 0.85rem;
    }

    .timeline {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .job-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .job h3 {
      margin: 0;
      font-size: 1rem;
      color: var(--color-yellow);
    }

    .period {
      font-size: 0.82rem;
      color: var(--color-text-muted);
      white-space: nowrap;
    }

    .company {
      margin: 0.2rem 0 0.6rem;
      color: var(--color-text-muted);
      font-size: 0.88rem;
    }

    .job ul {
      margin: 0;
      padding-left: 1.25rem;
    }

    .job li {
      margin-bottom: 0.35rem;
      font-size: 0.92rem;
    }

    .job li::marker {
      color: var(--color-green);
    }

    .skill-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
    }

    .skill-group h3 {
      font-size: 0.88rem;
      color: var(--color-text-muted);
      margin-bottom: 0.6rem;
    }

    .cert-list {
      padding-left: 1.25rem;
      margin: 0;
    }

    .cert-list li::marker {
      color: var(--color-green);
    }

    .muted {
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
