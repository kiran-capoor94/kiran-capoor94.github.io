---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { profile } from '../../data/cv';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const PROJECT_LABEL: Record<string, string> = {
  wizard: 'wizard',
  'wand-nvim': 'wand.nvim',
  essay: 'essay',
};

const PROJECT_CLASS: Record<string, string> = {
  wizard: 'badge-cyan',
  'wand-nvim': 'badge-yellow',
  essay: 'badge-magenta',
};

const words = (post.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: profile.name, url: Astro.site?.href },
  publisher: { '@type': 'Person', name: profile.name },
  keywords: post.data.tags.join(', '),
  url: canonical,
  mainEntityOfPage: canonical,
  image: new URL('/og-card.png', Astro.site).href,
};
---


<BaseLayout title={post.data.title} description={post.data.description} ogType="article">
  <article class="container page">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} is:inline />
    <div class="post-head">
      <span class:list={['badge', PROJECT_CLASS[post.data.project]]}>
        {PROJECT_LABEL[post.data.project]}
      </span>
      <p class="post-meta">
        {
          post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })
        }
        {' · '}
        {readingTime} min read
        {
          post.data.updatedDate && (
            <>
              {' · '}
              <span class="updated">
                updated{' '}
                {post.data.updatedDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
            </>
          )
        }
      </p>
    </div>
    <h1>{post.data.title}</h1>
    {
      post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )
    }

    <div class="tldr">
      <span class="tldr-label">// tl;dr</span>
      <p>{post.data.description}</p>
    </div>

    <div class="prose">
      <Content />
    </div>

    <RelatedPosts currentId={post.id} project={post.data.project} />

    <a class="back-link" href="/blog/">&larr; cd ../blog</a>
  </article>

  <style>
    .page {
      padding: 3rem 1.5rem 4rem;
      max-width: 720px;
    }

    .post-head {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
      flex-wrap: wrap;
    }

    .badge {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      border: 1px solid transparent;
    }

    .badge-cyan {
      color: var(--color-cyan);
      background: color-mix(in srgb, var(--color-cyan) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-cyan) 30%, transparent);
    }

    .badge-yellow {
      color: var(--color-yellow);
      background: color-mix(in srgb, var(--color-yellow) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-yellow) 30%, transparent);
    }

    .badge-magenta {
      color: var(--color-magenta);
      background: color-mix(in srgb, var(--color-magenta) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-magenta) 30%, transparent);
    }

    .post-meta {
      font-size: 0.82rem;
      color: var(--color-text-muted);
      margin: 0;
    }

    .updated {
      color: var(--color-green);
    }

    h1 {
      font-size: 1.9rem;
      margin: 0 0 1rem;
      color: var(--color-text);
    }

    .tags {
      margin-bottom: 1.5rem;
    }

    .tldr {
      border-left: 3px solid var(--color-accent);
      background: var(--color-bg-alt);
      border-radius: 0 6px 6px 0;
      padding: 0.9rem 1.1rem;
      margin: 0 0 2rem;
    }

    .tldr-label {
      display: block;
      font-size: 0.72rem;
      color: var(--color-accent);
      font-weight: 700;
      letter-spacing: 0.04em;
      margin-bottom: 0.35rem;
    }

    .tldr p {
      margin: 0;
      color: var(--color-text);
      font-size: 0.95rem;
      line-height: 1.55;
      font-family: var(--font-sans);
    }

    .prose {
      font-size: 1.02rem;
      line-height: 1.75;
      font-family: var(--font-sans);
    }

    /* headings and code stay in the terminal's mono voice */
    .prose :global(h2) {
      margin-top: 2rem;
      font-size: 1.3rem;
      color: var(--color-yellow);
      font-family: var(--font-mono);
    }

    .prose :global(h3) {
      margin-top: 1.5rem;
      font-size: 1.05rem;
      font-family: var(--font-mono);
    }

    .prose :global(p) {
      margin: 1rem 0;
    }

    .prose :global(a) {
      text-decoration: underline;
    }

    .prose :global(ul),
    .prose :global(ol) {
      padding-left: 1.5rem;
    }

    .prose :global(pre) {
      margin: 1.25rem 0;
      font-size: 0.85rem;
      line-height: 1.6;
    }

    .prose :global(blockquote) {
      margin: 1.25rem 0;
      padding: 0.1rem 1.1rem;
      border-left: 3px solid var(--color-green);
      color: var(--color-text-muted);
    }

    .prose :global(svg) {
      margin: 1.5rem 0;
      display: block;
    }

    .back-link {
      display: inline-block;
      margin-top: 2.5rem;
      font-size: 0.9rem;
    }
  </style>
</BaseLayout>
