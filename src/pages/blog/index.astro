---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PROJECT_LABEL: Record<string, string> = {
  wizard: 'wizard',
  'wand-nvim': 'wand.nvim',
  essay: 'essay',
};

const PROJECT_CLASS: Record<string, string> = {
  wizard: 'badge-cyan',
  'wand-nvim': 'badge-yellow',
  essay: 'badge-magenta',
};

function readingTime(body: string | undefined): number {
  const words = (body ?? '').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}
---

<BaseLayout title="Blog" description="Writing on software engineering, AI tooling, and how I work.">
  <div class="container page">
    <p class="prompt-line"><span class="prompt">git log --oneline blog/</span></p>
    <h1><span class="hash">#</span> blog</h1>
    <p class="intro muted">// real gotchas from real repos, not posts for the sake of posting.</p>

    {
      posts.length === 0 ? (
        <div class="empty">
          <p>// nothing published yet.</p>
          <p class="muted">
            <span class="prompt">subscribe</span> via <a href="/rss.xml">rss</a> and check back soon.
          </p>
        </div>
      ) : (
        <div class="post-grid">
          {posts.map((post) => (
            <a class="post-card" href={`/blog/${post.id}/`} data-reveal>
              <div class="post-card-head">
                <span class:list={['badge', PROJECT_CLASS[post.data.project]]}>
                  {PROJECT_LABEL[post.data.project]}
                </span>
                <span class="post-meta">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  {' · '}
                  {readingTime(post.body)} min read
                </span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((tag) => (
                    <span class="tag-pill">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      )
    }
  </div>

  <style>
    .page {
      padding: 3rem 1.5rem 4rem;
    }

    .prompt-line {
      margin-bottom: 0.5rem;
    }

    h1 {
      font-size: 1.8rem;
      margin: 0 0 0.5rem;
      color: var(--color-cyan);
    }

    .hash {
      color: var(--color-magenta);
    }

    .intro {
      margin-bottom: 2.5rem;
    }

    .empty {
      border: 1px dashed var(--color-border);
      border-radius: 6px;
      padding: 2.5rem;
      text-align: center;
      background: var(--color-bg-alt);
    }

    .muted {
      color: var(--color-text-muted);
    }

    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.5rem;
    }

    .post-card {
      display: block;
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 1.5rem;
      background: var(--color-bg-alt);
      color: var(--color-text);
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .post-card:hover {
      border-color: var(--color-accent);
      transform: translateY(-2px);
      text-decoration: none;
      color: var(--color-text);
    }

    .post-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
      flex-wrap: wrap;
    }

    .badge {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      border: 1px solid transparent;
    }

    .badge-cyan {
      color: var(--color-cyan);
      background: color-mix(in srgb, var(--color-cyan) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-cyan) 30%, transparent);
    }

    .badge-yellow {
      color: var(--color-yellow);
      background: color-mix(in srgb, var(--color-yellow) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-yellow) 30%, transparent);
    }

    .badge-magenta {
      color: var(--color-magenta);
      background: color-mix(in srgb, var(--color-magenta) 12%, transparent);
      border-color: color-mix(in srgb, var(--color-magenta) 30%, transparent);
    }

    .post-meta {
      font-size: 0.78rem;
      color: var(--color-text-muted);
    }

    .post-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin: 0 0 0.5rem;
      color: var(--color-text);
    }

    .post-card:hover .post-title {
      color: var(--color-accent);
    }

    .post-desc {
      margin: 0 0 0.75rem;
      color: var(--color-text-muted);
      font-size: 0.9rem;
      line-height: 1.55;
      font-family: var(--font-sans);
    }

    .post-tags {
      margin-top: 0.5rem;
    }
  </style>
</BaseLayout>
