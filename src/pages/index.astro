---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile, projects } from '../data/cv';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const highlightProjects = projects.slice(0, 3);
---

<BaseLayout title="Home">
  <section class="container hero-section">
    <div class="term-window">
      <div class="term-titlebar">
        <span class="term-dot red"></span>
        <span class="term-dot yellow"></span>
        <span class="term-dot green"></span>
        <span class="term-titletext">kiran@portfolio: ~</span>
      </div>
      <div class="term-body">
        <p class="line"><span class="prompt">whoami</span></p>
        <p class="output name">{profile.name}</p>
        <p class="line"><span class="prompt">cat role.txt</span></p>
        <p class="output">{profile.role} &middot; {profile.location}</p>
        <p class="line"><span class="prompt">cat pitch.txt</span></p>
        <p class="output pitch">{profile.tagline}</p>
        <p class="line"><span class="prompt">ls contact/</span><span class="cursor blink">&#9608;</span></p>
        <div class="cta-row">
          <a class="button primary" href="/about/">./view-cv.sh</a>
          <a class="button" href={`mailto:${profile.email}`}>mailto:kiran</a>
          <a class="button" href={profile.linkedin} target="_blank" rel="noopener noreferrer">linkedin://</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <h2><span class="hash">#</span> side_projects</h2>
      <a href="/projects/">ls -la &rarr;</a>
    </div>
    <div class="card-grid">
      {
        highlightProjects.map((project) => (
          <div class="card">
            <h3><span class="dir-icon">/</span>{project.name}</h3>
            <p>{project.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <h2><span class="hash">#</span> latest_writing</h2>
      <a href="/blog/">tail -f &rarr;</a>
    </div>
    {
      posts.length === 0 ? (
        <p class="muted">// no posts yet — first one is coming soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              <span class="muted"> — {post.data.description}</span>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <style>
    .hero-section {
      padding: 3rem 1.5rem 2rem;
    }

    .line {
      margin: 1.1rem 0 0.2rem;
    }

    .line:first-child {
      margin-top: 0;
    }

    .output {
      margin: 0 0 0.2rem;
      color: var(--color-text);
    }

    .output.name {
      color: var(--color-cyan);
      font-size: 1.6rem;
      font-weight: 700;
    }

    .output.pitch {
      max-width: 62ch;
      color: var(--color-text);
    }

    .cursor {
      margin-left: 0.35rem;
      color: var(--color-green);
    }

    .cta-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    .button {
      display: inline-block;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 0.55rem 1rem;
      font-size: 0.9rem;
      color: var(--color-text);
      background: var(--color-bg-raised);
    }

    .button:hover {
      border-color: var(--color-accent);
      color: var(--color-accent);
      text-decoration: none;
    }

    .button.primary {
      background: var(--color-green);
      border-color: var(--color-green);
      color: var(--color-bg);
      font-weight: 700;
    }

    .button.primary:hover {
      color: var(--color-bg);
      opacity: 0.9;
    }

    .section {
      padding: 2.5rem 1.5rem;
    }

    .section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .section-head h2 {
      font-size: 1.15rem;
      margin: 0;
      color: var(--color-text);
    }

    .hash {
      color: var(--color-magenta);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1.25rem;
    }

    .card {
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 1.25rem;
      background: var(--color-bg-alt);
    }

    .card:hover {
      border-color: var(--color-accent);
    }

    .card h3 {
      margin: 0 0 0.5rem;
      font-size: 1rem;
      color: var(--color-yellow);
    }

    .dir-icon {
      color: var(--color-text-muted);
    }

    .card p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.88rem;
    }

    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .post-list li {
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .muted {
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
