---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile, projects } from '../data/cv';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const highlightProjects = projects.slice(0, 3);
---

<BaseLayout title="Home">
  <section class="container hero-section">
    <div class="term-window">
      <div class="term-titlebar">
        <span class="term-dot red"></span>
        <span class="term-dot yellow"></span>
        <span class="term-dot green"></span>
        <span class="term-titletext">kiran@portfolio: ~</span>
      </div>
      <div class="term-body">
        <p class="line"><span class="prompt">whoami</span></p>
        <p class="output name">{profile.name}</p>
        <p class="line"><span class="prompt">cat role.txt</span></p>
        <p class="output">{profile.role} &middot; {profile.location}</p>
        <p class="line"><span class="prompt">cat pitch.txt</span></p>
        <p class="output pitch">{profile.tagline}</p>
        <div id="term-log" aria-live="polite"></div>
        <p class="line prompt-line">
          <label for="term-input" class="visually-hidden">Terminal command input — type help and press enter</label>
          <span class="prompt-symbol">$</span>
          <input
            id="term-input"
            class="term-input"
            type="text"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            placeholder="type 'help' and press enter"
          />
        </p>
        <div class="cta-row">
          <a class="button primary" href="/about/">./view-cv.sh</a>
          <a class="button" href={`mailto:${profile.email}`}>mailto:kiran</a>
          <a class="button" href={profile.linkedin} target="_blank" rel="noopener noreferrer">linkedin://</a>
        </div>
      </div>
    </div>
  </section>

  <script
    define:vars={{
      email: profile.email,
      github: profile.github,
      linkedin: profile.linkedin,
      youtube: profile.youtube,
    }}
  >
    (function () {
      const input = document.getElementById('term-input');
      const log = document.getElementById('term-log');
      if (!input || !log) return;

      function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      function appendCommand(cmd) {
        const p = document.createElement('p');
        p.className = 'line';
        p.innerHTML = '<span class="prompt">' + escapeHtml(cmd) + '</span>';
        log.appendChild(p);
      }

      function appendOutput(html) {
        const p = document.createElement('p');
        p.className = 'output';
        p.innerHTML = html;
        log.appendChild(p);
      }

      function goTo(path, label) {
        appendOutput('&rarr; ' + label);
        window.setTimeout(() => {
          window.location.href = path;
        }, 350);
      }

      function openExternal(url, label) {
        appendOutput('&rarr; ' + label);
        window.open(url, '_blank', 'noopener,noreferrer');
      }

      const HELP =
        'available commands:<br>' +
        '&nbsp;&nbsp;help &mdash; show this list<br>' +
        '&nbsp;&nbsp;about, whoami &mdash; open the CV page<br>' +
        '&nbsp;&nbsp;projects, ls &mdash; open the projects page<br>' +
        '&nbsp;&nbsp;blog &mdash; open the blog<br>' +
        '&nbsp;&nbsp;contact, mail &mdash; email me<br>' +
        '&nbsp;&nbsp;github, linkedin, youtube &mdash; open my profiles<br>' +
        '&nbsp;&nbsp;date &mdash; current date/time<br>' +
        '&nbsp;&nbsp;echo &lt;text&gt; &mdash; print text back<br>' +
        '&nbsp;&nbsp;clear &mdash; clear the screen';

      function run(raw) {
        const cmd = raw.trim();
        appendCommand(cmd);
        if (!cmd) return;

        const [word, ...rest] = cmd.split(/\s+/);
        const arg = rest.join(' ');
        const lower = word.toLowerCase();

        switch (lower) {
          case 'help':
            appendOutput(HELP);
            break;
          case 'about':
          case 'whoami':
            goTo('/about/', 'opening about page...');
            break;
          case 'projects':
          case 'ls':
            goTo('/projects/', 'opening projects page...');
            break;
          case 'blog':
            goTo('/blog/', 'opening blog...');
            break;
          case 'contact':
          case 'mail':
            openExternal('mailto:' + email, 'opening mail client...');
            break;
          case 'github':
            openExternal(github, 'opening github...');
            break;
          case 'linkedin':
            openExternal(linkedin, 'opening linkedin...');
            break;
          case 'youtube':
            openExternal(youtube, 'opening youtube...');
            break;
          case 'date':
            appendOutput(new Date().toString());
            break;
          case 'echo':
            appendOutput(escapeHtml(arg));
            break;
          case 'clear':
          case 'cls':
            log.innerHTML = '';
            break;
          case 'sudo':
            appendOutput("kiran is not in the sudoers file. this incident will be reported. (jk &mdash; try 'help')");
            break;
          default:
            appendOutput('command not found: ' + escapeHtml(word) + " &mdash; try 'help'");
        }
      }

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          run(input.value);
          input.value = '';
        }
      });

      document.querySelector('.term-window')?.addEventListener('click', () => input.focus());
    })();
  </script>

  <section class="container section">
    <div class="section-head">
      <h2><span class="hash">#</span> side_projects</h2>
      <a href="/projects/">ls -la &rarr;</a>
    </div>
    <div class="card-grid">
      {
        highlightProjects.map((project) => (
          <div class="card">
            <h3><span class="dir-icon">/</span>{project.name}</h3>
            <p>{project.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <h2><span class="hash">#</span> latest_writing</h2>
      <a href="/blog/">tail -f &rarr;</a>
    </div>
    {
      posts.length === 0 ? (
        <p class="muted">// no posts yet — first one is coming soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <span class="muted"> — {post.data.description}</span>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <style>
    .hero-section {
      padding: 3rem 1.5rem 2rem;
    }

    .line {
      margin: 1.1rem 0 0.2rem;
    }

    .line:first-child {
      margin-top: 0;
    }

    .output {
      margin: 0 0 0.2rem;
      color: var(--color-text);
    }

    .output.name {
      color: var(--color-cyan);
      font-size: 1.6rem;
      font-weight: 700;
    }

    .output.pitch {
      max-width: 62ch;
      color: var(--color-text);
    }

    .cursor {
      margin-left: 0.35rem;
      color: var(--color-green);
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    #term-log :global(.line) {
      margin: 1.1rem 0 0.2rem;
    }

    #term-log :global(.output) {
      margin: 0 0 0.2rem;
      color: var(--color-text);
    }

    .prompt-line {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin: 1.1rem 0 0.2rem;
    }

    .prompt-symbol {
      color: var(--color-green);
    }

    .term-input {
      all: unset;
      flex: 1;
      font-family: var(--font-mono);
      font-size: inherit;
      color: var(--color-text);
      caret-color: var(--color-green);
      min-width: 0;
    }

    .term-input::placeholder {
      color: var(--color-text-muted);
    }

    .cta-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    .button {
      display: inline-block;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 0.55rem 1rem;
      font-size: 0.9rem;
      color: var(--color-text);
      background: var(--color-bg-raised);
    }

    .button:hover {
      border-color: var(--color-accent);
      color: var(--color-accent);
      text-decoration: none;
    }

    .button.primary {
      background: var(--color-green);
      border-color: var(--color-green);
      color: var(--color-bg);
      font-weight: 700;
    }

    .button.primary:hover {
      color: var(--color-bg);
      opacity: 0.9;
    }

    .section {
      padding: 2.5rem 1.5rem;
    }

    .section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .section-head h2 {
      font-size: 1.15rem;
      margin: 0;
      color: var(--color-text);
    }

    .hash {
      color: var(--color-magenta);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1.25rem;
    }

    .card {
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 1.25rem;
      background: var(--color-bg-alt);
    }

    .card:hover {
      border-color: var(--color-accent);
    }

    .card h3 {
      margin: 0 0 0.5rem;
      font-size: 1rem;
      color: var(--color-yellow);
    }

    .dir-icon {
      color: var(--color-text-muted);
    }

    .card p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.88rem;
    }

    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .post-list li {
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .muted {
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
