---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Command not found">
  <div class="container not-found">
    <div class="term-window">
      <div class="term-titlebar">
        <span class="term-dot red"></span>
        <span class="term-dot yellow"></span>
        <span class="term-dot green"></span>
        <span class="term-titletext">kiran@portfolio: ~</span>
      </div>
      <div class="term-body">
        <p><span class="prompt">{Astro.url.pathname}</span></p>
        <p class="error">zsh: command not found: {Astro.url.pathname}</p>
        <p class="muted">// this route never shipped. probably a typo, possibly a feature I haven't built yet.</p>
        <p><a href="/">cd ~</a> <span class="muted">// the only path guaranteed to exist</span></p>
      </div>
    </div>
  </div>

  <style>
    .not-found {
      padding: 5rem 1.5rem;
    }

    .error {
      color: var(--color-red);
    }

    .muted {
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
