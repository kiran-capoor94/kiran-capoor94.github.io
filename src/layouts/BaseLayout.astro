---
import '../styles/global.css';
import { profile } from '../data/cv';
import CommandPalette from '../components/CommandPalette.astro';
import LivingGrid from '../components/LivingGrid.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  image?: string;
}

const {
  title,
  description = profile.tagline,
  ogType = 'website',
  image = '/og-card.png',
} = Astro.props;
const ogImage = new URL(image, Astro.site).href;
const navItems = [
  { href: '/', label: 'home', key: '1' },
  { href: '/about/', label: 'about', key: '2' },
  { href: '/projects/', label: 'projects', key: '3' },
  { href: '/uses/', label: 'uses', key: '4' },
  { href: '/blog/', label: 'blog', key: '5' },
];
const currentPath = Astro.url.pathname;

// Person structured data for rich search results (#9)
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.role,
  description: profile.tagline,
  email: `mailto:${profile.email}`,
  url: Astro.site?.href,
  address: { '@type': 'PostalAddress', addressLocality: profile.location },
  sameAs: [profile.github, profile.linkedin, profile.youtube],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a1b26" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={profile.name} href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · {profile.name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(currentPath, Astro.site).href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={new URL(currentPath, Astro.site).href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />
  </head>
  <body>
    <LivingGrid />
    <a href="#main" class="skip-link">skip to content</a>

    <div id="boot-overlay" class="boot-overlay" aria-hidden="true" role="presentation">
      <div id="boot-lines" class="boot-lines"></div>
      <p class="boot-skip">press any key or click to skip</p>
    </div>

    <header class="tmux-bar">
      <div class="container tmux-inner">
        <a class="brand" href="/">
          <span class="prompt-icon">&gt;</span> kiran@portfolio
        </a>
        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" id="nav-toggle">
          <span></span><span></span><span></span>
        </button>
        <nav id="site-nav">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                data-key={item.key}
                title={`press ${item.key} to jump here`}
                class:list={['tab', { active: currentPath === item.href }]}
              >
                <span class="tab-key">{item.key}</span>
                {item.label}
              </a>
            ))
          }
          <button
            type="button"
            class="cmdk-trigger"
            data-open-palette
            aria-label="Open command palette (Control or Command + K)"
          >
            <span class="tab-key">⌘</span>k
          </button>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <CommandPalette />

    <footer class="site-footer">
      <div class="container footer-inner">
        <span>&copy; {new Date().getFullYear()} {profile.name} <span class="muted">// built with astro</span></span>
        <div class="footer-links">
          <a href={`mailto:${profile.email}`}>email</a>
          <a href={profile.github} target="_blank" rel="noopener noreferrer">github</a>
          <a href={profile.linkedin} target="_blank" rel="noopener noreferrer">linkedin</a>
          <a href={profile.youtube} target="_blank" rel="noopener noreferrer">youtube</a>
          <a href="/rss.xml">rss</a>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('site-nav');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        nav?.classList.toggle('open');
      });

      // keyboard nav: the 1/2/3/4 badges next to each tab are real shortcuts
      const keyMap = new Map<string, string>();
      nav?.querySelectorAll<HTMLAnchorElement>('a[data-key]').forEach((link) => {
        const key = link.dataset.key;
        if (key) keyMap.set(key, link.href);
      });

      document.addEventListener('keydown', (event) => {
        if (event.ctrlKey || event.metaKey || event.altKey) return;

        // Escape closes the open mobile menu regardless of where focus sits
        if (event.key === 'Escape' && nav?.classList.contains('open')) {
          nav.classList.remove('open');
          toggle?.setAttribute('aria-expanded', 'false');
          toggle?.focus();
          return;
        }

        const target = event.target as HTMLElement | null;
        // don't hijack single keys while focus is on any interactive control
        // (input, link, button, etc.) — WCAG 2.1.4 Character Key Shortcuts
        const onInteractive =
          target &&
          target !== document.body &&
          target.closest('a, button, input, textarea, select, [tabindex], [contenteditable]');
        if (onInteractive) return;

        const href = keyMap.get(event.key);
        if (href) window.location.href = href;
      });
    </script>

    <script>
      // signature moment: a fake boot sequence, once per session, skippable, motion-safe
      const overlay = document.getElementById('boot-overlay');
      const linesEl = document.getElementById('boot-lines');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (overlay && linesEl) {
        if (sessionStorage.getItem('kc_booted') || reduceMotion) {
          overlay.remove();
        } else {
          const bootLines = [
            '[ OK ] booting kernel...',
            '[ OK ] mounting /dev/skills...',
            '[ OK ] starting agent-memory.service...',
            '[FAIL] coffee not found. continuing anyway.',
            '[ OK ] loading personality.so...',
            'welcome. type freely, nothing here bites.',
          ];

          let cancelled = false;
          let timeoutId: number | undefined;

          const finishBoot = () => {
            sessionStorage.setItem('kc_booted', '1');
            overlay.classList.add('boot-hide');
            window.setTimeout(() => overlay.remove(), 300);
          };

          const skip = () => {
            if (cancelled) return;
            cancelled = true;
            window.clearTimeout(timeoutId);
            finishBoot();
          };

          const typeLine = (lineIndex: number) => {
            if (cancelled) return;
            if (lineIndex >= bootLines.length) {
              timeoutId = window.setTimeout(finishBoot, 500);
              return;
            }
            const line = bootLines[lineIndex];
            const p = document.createElement('p');
            linesEl.appendChild(p);
            let charIndex = 0;
            const typeChar = () => {
              if (cancelled) return;
              if (charIndex <= line.length) {
                p.textContent = line.slice(0, charIndex);
                charIndex++;
                timeoutId = window.setTimeout(typeChar, 14);
              } else {
                if (line.startsWith('[FAIL]')) p.classList.add('boot-fail');
                else if (line.startsWith('[ OK ]')) p.classList.add('boot-ok');
                timeoutId = window.setTimeout(() => typeLine(lineIndex + 1), 140);
              }
            };
            typeChar();
          };

          overlay.addEventListener('click', skip);
          document.addEventListener('keydown', skip, { once: true });
          typeLine(0);
        }
      }
    </script>

    <script>
      // scroll-reveal: fade+rise elements marked data-reveal as they enter the viewport
      const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
      const reduceMotionReveal = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (revealEls.length) {
        if (reduceMotionReveal || !('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-visible'));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
          );
          revealEls.forEach((el) => io.observe(el));
        }
      }
    </script>

    <style>
      .boot-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: var(--color-bg);
        color: var(--color-text);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 2rem;
        cursor: pointer;
        opacity: 1;
        transition: opacity 0.3s ease;
      }

      .boot-overlay.boot-hide {
        opacity: 0;
      }

      .boot-lines {
        max-width: 640px;
        margin: 0 auto;
        width: 100%;
      }

      .boot-lines p {
        margin: 0.35rem 0;
        min-height: 1.2em;
      }

      .boot-lines p.boot-ok {
        color: var(--color-green);
      }

      .boot-lines p.boot-fail {
        color: var(--color-red);
      }

      .boot-skip {
        max-width: 640px;
        margin: 1.5rem auto 0;
        width: 100%;
        color: var(--color-text-muted);
        font-size: 0.82rem;
      }

      .tmux-bar {
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        background: var(--color-bg-alt);
        z-index: 10;
      }

      .tmux-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 52px;
      }

      .brand {
        font-weight: 600;
        color: var(--color-text);
        font-size: 0.95rem;
      }

      .brand:hover {
        color: var(--color-green);
        text-decoration: none;
      }

      .prompt-icon {
        color: var(--color-green);
      }

      #site-nav {
        display: flex;
        gap: 0.25rem;
      }

      .tab {
        color: var(--color-text-muted);
        font-size: 0.88rem;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        border: 1px solid transparent;
      }

      .tab-key {
        color: var(--color-magenta);
        margin-right: 0.35rem;
      }

      .tab:hover {
        color: var(--color-text);
        border-color: var(--color-border);
        text-decoration: none;
      }

      .tab.active {
        color: var(--color-bg);
        background: var(--color-accent);
        text-decoration: none;
      }

      .tab.active .tab-key {
        color: var(--color-bg);
        opacity: 0.7;
      }

      .cmdk-trigger {
        font-family: var(--font-mono);
        color: var(--color-text-muted);
        font-size: 0.88rem;
        padding: 0.35rem 0.6rem;
        border-radius: 4px;
        border: 1px solid var(--color-border);
        background: none;
        cursor: pointer;
        margin-left: 0.35rem;
      }

      .cmdk-trigger:hover {
        color: var(--color-text);
        border-color: var(--color-accent);
      }

      .cmdk-trigger .tab-key {
        color: var(--color-magenta);
        margin-right: 0.15rem;
      }

      .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
      }

      .nav-toggle span {
        width: 22px;
        height: 2px;
        background: var(--color-text);
        display: block;
      }

      main {
        min-height: calc(100vh - 52px - 90px);
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        margin-top: 4rem;
        background: var(--color-bg-alt);
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem;
        color: var(--color-text-muted);
        font-size: 0.85rem;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer-links {
        display: flex;
        gap: 1.25rem;
      }

      @media (max-width: 640px) {
        .nav-toggle {
          display: flex;
        }

        #site-nav {
          display: none;
          position: absolute;
          top: 52px;
          left: 0;
          right: 0;
          background: var(--color-bg-alt);
          border-bottom: 1px solid var(--color-border);
          flex-direction: column;
          gap: 0;
          padding: 0.5rem;
        }

        #site-nav.open {
          display: flex;
        }

        .tab {
          padding: 0.75rem 1rem;
        }
      }
    </style>
  </body>
</html>
